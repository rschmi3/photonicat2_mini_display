{
  "display_template": {
    "elements": {
      "page0": [
        {
          "type": "fixed_text",
          "label": "Disk Free",
          "position": {
            "x": 100,
            "y": 235
          },
          "font": "tiny",
          "color": [255, 229, 0],
          "enable": 0
        },
        {
          "type": "text",
          "position": {
            "x": 100,
            "y": 250
          },
          "font": "unit",
          "color": [255, 229, 255],
          "units": "MB",
          "data_key": "DiskFreeMB",
          "units_font": "tiny",
          "enable": 0
        }
      ]
    }
  },
  "custom_metrics": {
    "sources": [
      {
        "type": "command",
        "name": "DiskFree",
        "enabled": 0,
        "config": {
          "command": "./get_disk_free_mb.sh",
          "interval": 10,
          "timeout": 2,
          "parser": "stdout",
          "data_key": "DiskFreeMB"
        }
      },
      {
        "type": "command",
        "name": "DiskFreeAlternative",
        "enabled": 0,
        "config": {
          "command": "df / | awk 'NR==2 {print int($4/1024)}'",
          "interval": 10,
          "timeout": 2,
          "parser": "stdout",
          "data_key": "DiskFreeMB"
        }
      },
      {
        "type": "http",
        "name": "RemoteDiskMetrics",
        "enabled": 0,
        "config": {
          "url": "http://your-server:8080/metrics/disk",
          "method": "GET",
          "interval": 30,
          "timeout": 5,
          "parser": "json",
          "data_mappings": [
            {
              "source_path": "disk.free_mb",
              "data_key": "RemoteDiskFreeMB"
            }
          ]
        }
      },
      {
        "type": "env",
        "name": "EnvironmentMetrics",
        "enabled": 0,
        "config": {
          "variables": [
            {
              "env_name": "CUSTOM_DISK_FREE",
              "data_key": "EnvDiskFreeMB"
            }
          ]
        }
      },
      {
        "type": "json_file",
        "name": "JSONFileMetrics",
        "enabled": 0,
        "config": {
          "file_path": "/tmp/metrics.json",
          "watch_interval": 5,
          "data_mappings": [
            {
              "source_path": "disk.free_mb",
              "data_key": "JSONDiskFreeMB"
            }
          ]
        }
      }
    ],
    "global_settings": {
      "enable_logging": 1,
      "error_retry_interval": 30,
      "max_retries": 3
    }
  }
}
